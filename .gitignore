.env*
!.env.example

# 🔹 Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 🔹 System files
.DS_Store
Thumbs.db

# 🔹 Certificates / keys
*.pem
*.key

# 🔹 Vercel
.vercel

