generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  password      String?

  role          Role      @default(CUSTOMER)

  phone         String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  alternative_mobile_number String?
  dob           DateTime?

  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth
  accounts      Account[]
  sessions      Session[]

  // Profiles
  providerProfile ProviderProfile?

  // Admin-managed delivery hiring
  createdDeliveryInvites DeliveryPartnerInvite[] @relation("DeliveryInviteCreatedBy")

  // Orders
  customerOrders Order[] @relation("CustomerOrders")
  addresses      CustomerAddress[]
  
  // Wishlist
  wishlists     Wishlist[]

  // Cart
  cartItems     CartItem[]

  @@map("user")
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

model CustomerAddress {
  id          String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String?
  name         String?
  addressLine  String
  city         String?
  state        String?
  pincode      String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, createdAt])
}

model DeliveryPartnerInvite {
  id               String   @id @default(uuid())
  email            String
  fullName         String
  phone            String?
  tokenHash        String   @unique
  expiresAt        DateTime
  usedAt           DateTime?
  createdByAdminId String
  createdByAdmin   User     @relation("DeliveryInviteCreatedBy", fields: [createdByAdminId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@index([email, expiresAt])
}

model DeliveryPartnerProfile {
  id            String                @id @default(uuid())
  email         String                @unique
  fullName      String
  passwordHash  String
  employeeCode  String                @unique
  phone         String?
  city          String?
  pincode       String?
  vehicleNumber String?
  status        DeliveryPartnerStatus @default(ACTIVE)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  tasks         DeliveryTask[]
  sessions      DeliveryPartnerSession[]

  @@index([status])
}

model DeliveryPartnerSession {
  id                String               @id @default(uuid())
  token             String               @unique
  deliveryPartnerId String
  deliveryPartner   DeliveryPartnerProfile @relation(fields: [deliveryPartnerId], references: [id], onDelete: Cascade)
  expiresAt         DateTime
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([deliveryPartnerId])
  @@index([expiresAt])
}

enum DeliveryPartnerStatus {
  ACTIVE
  SUSPENDED
}

model DeliveryTask {
  id                    String                @id @default(uuid())
  orderId               String                @unique
  order                 Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryPartnerId     String
  deliveryPartner       DeliveryPartnerProfile @relation(fields: [deliveryPartnerId], references: [id], onDelete: Cascade)
  stage                 DeliveryTaskStage     @default(ASSIGNED)
  pickupProofImage      String?
  deliveryProofImage    String?
  returnPickupProofImage String?
  providerDropProofImage String?
  notes                 String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([deliveryPartnerId, stage])
}

enum DeliveryTaskStage {
  ASSIGNED
  PICKED_UP_FROM_PROVIDER
  DELIVERED_TO_CUSTOMER
  PICKED_UP_FROM_CUSTOMER
  DELIVERED_TO_PROVIDER
  CLOSED
}

model ProviderProfile {
  id           String   @id @default(uuid())

  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  providerType ProviderType?
  businessName String?
  phone        String
  alternate_phone String?
  address      String?
  city         String?
  state        String?
  pincode      String?
  description  String?
  profilePhoto String?
  bankAccountNumber String? 
  bankIfsc          String? 
  bankAccountName   String? 
  panNumber    String?  
  idDocument   String?  
  signature    String?  

  stepMobileVerified   Boolean @default(false) // Step 1
  stepIdentityVerified Boolean @default(false) // Step 2
  stepStoreDetails     Boolean @default(false) // Step 3
  stepPickupAddress    Boolean @default(false) // Step 4
  stepBankDetails      Boolean @default(false) // Step 5
  stepFirstListing     Boolean @default(false) // Step 6

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Provider-owned commerce entities
  listings     Listing[] @relation("ProviderListings")
  providerOrders Order[] @relation("ProviderOrders")
}

enum ProviderType {
  BOUTIQUE
  RENTAL
}

model Listing {
  id          String   @id @default(uuid())

  providerId  String
  provider    ProviderProfile @relation("ProviderListings", fields: [providerId], references: [id], onDelete: Cascade)

  title       String
  Fabric      String
  size        String   @default("Free Size")
  
  images      String[]
  description String?
  originalPrice Float    @default(0)
  price       Float
  category    String
  color       String   @default("Assorted")

  status      Boolean  @default(true)
  stockQuantity Int     @default(1)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews     ListingReview[]
  orders      Order[]  @relation("ListingOrders")
  wishlists   Wishlist[]
  cartItems   CartItem[]

  @@index([providerId])
  @@index([status, createdAt])
}

model ListingReview {
  id            String   @id @default(uuid())
  listingId     String
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  reviewerName  String
  reviewerEmail String?
  rating        Int
  title         String?
  comment       String
  imageUrl      String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([listingId])
  @@index([listingId, reviewerEmail])
}

model Order {
  id          String   @id @default(uuid())

  listingId   String
  listing     Listing  @relation("ListingOrders", fields: [listingId], references: [id], onDelete: Cascade)

  userId      String
  user        User     @relation("CustomerOrders", fields: [userId], references: [id])

  providerId  String
  provider    ProviderProfile @relation("ProviderOrders", fields: [providerId], references: [id])

  quantity    Int      @default(1)
  total       Float

  status      OrderStatus @default(PENDING)

  deliveryName        String?
  deliveryAddressLine String?
  deliveryCity        String?
  deliveryState       String?
  deliveryPincode     String?

  // Rental lifecycle dates (set at order creation, updated as status changes)
  rentalStartDate    DateTime?  // Expected delivery date = createdAt + 7 days
  rentalEndDate      DateTime?  // rentalStartDate + 3 days (end of rental period)
  expectedReturnDate DateTime?  // rentalEndDate + 5 days (return + inspection + ready again)

  // Real-time milestone timestamps (updated when actors change status/stage)
  acceptedAt            DateTime?
  shippedAt             DateTime?
  pickedUpFromProviderAt DateTime?
  deliveredToCustomerAt DateTime?
  pickedUpFromCustomerAt DateTime?
  returnedToProviderAt  DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deliveryTask DeliveryTask?

  @@index([providerId, createdAt])
  @@index([providerId, status, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

enum OrderStatus {
  PENDING        // Order placed, awaiting provider confirmation
  ACCEPTED       // Provider confirmed, preparing dispatch
  SHIPPED        // Item dispatched to customer (7-day delivery window)
  WITH_CUSTOMER  // Customer received item, 3-day rental period active
  RETURNED       // Item returned to provider, verifying condition
  COMPLETED      // Full cycle done, security deposit released
  CANCELLED      // Order cancelled
}

model Account {
  id                    String   @id @default(uuid())
  userId                String
  
  accountId  String
  providerId String

  accessToken          String?  @db.Text
  refreshToken         String?  @db.Text
  idToken              String?  @db.Text

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  scope                 String?   
 
  password              String?    
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([accountId, providerId])
  @@index([userId])
  @@map("account")
}

model Session {
  id           String   @id @default(uuid())
  token        String   @unique
  userId       String

  expiresAt    DateTime

  ipAddress    String?
  userAgent    String?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt


  @@index([identifier])
  @@map("verification")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}