# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://username:password@host:5432/database

# Better Auth / Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email OTP (auth signup)
RESEND_API_KEY=

# Provider mobile OTP
MOBILE_OTP_SECRET=replace-with-strong-random-secret
MOBILE_OTP_DEBUG=true

# Twilio (use either phone number or messaging service sid)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_VERIFY_SERVICE_SID=

# Manual QR UPI checkout
NEXT_PUBLIC_PAYMENT_UPI_ID=
NEXT_PUBLIC_PAYMENT_UPI_NAME=noorat
# Optional: host your own QR image URL. If empty, QR is generated from UPI link.
NEXT_PUBLIC_PAYMENT_QR_IMAGE_URL=
